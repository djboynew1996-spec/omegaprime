# ==================================================================================
# OMEGA PRIME - PRODUCTION ENVIRONMENT CONFIGURATION
# ==================================================================================

# Security (CRITICAL - Change these values!)
OMEGA_SECRET_KEY=GenerateStrongSecretKeyHere123!@#$%^&*()

# Database
OMEGA_DB_PATH=./data/omega_data.json
POSTGRES_PASSWORD=ChangeThisStrongPassword123!
REDIS_PASSWORD=ChangeThisRedisPassword456!

# Performance Tuning
OMEGA_MAX_CONCURRENT=50
OMEGA_RATE_LIMIT=60

# Monitoring
GRAFANA_PASSWORD=admin

# Logging
LOG_LEVEL=INFO

# ==================================================================================
# INSTRUCTIONS FOR DEPLOYMENT
# ==================================================================================
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Generate strong secrets:
#    OMEGA_SECRET_KEY: openssl rand -base64 32
#    POSTGRES_PASSWORD: openssl rand -base64 24
#    REDIS_PASSWORD: openssl rand -base64 24
#
# 3. Adjust performance settings based on your hardware:
#    - OMEGA_MAX_CONCURRENT: Number of parallel tasks (recommend: CPU cores * 2)
#    - OMEGA_RATE_LIMIT: Requests per minute per user
#
# 4. Never commit .env to version control!
#    Add .env to .gitignore
#
# ==================================================================================
