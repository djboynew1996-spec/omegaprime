# ======================================================================
# OMEGA PRIME — .gitignore
# Protect secrets, build artifacts, and environment files
# ======================================================================

# ------------------------------------------------------------------
# Environment & Secrets (NEVER commit these!)
# ------------------------------------------------------------------
.env
.env.local
.env.production
.env.development
*.lic
omega.lic
license.lic
OMEGA_LICENSE

# ------------------------------------------------------------------
# Build Output
# ------------------------------------------------------------------
bin/
obj/
dist/
build/
out/
*.exe
*.dll
*.pdb
*.so
*.dylib

# ------------------------------------------------------------------
# IDE & Editor
# ------------------------------------------------------------------
.vs/
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.swp
*.swo
*~

# ------------------------------------------------------------------
# OS Files
# ------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ------------------------------------------------------------------
# Logs & Data
# ------------------------------------------------------------------
*.log
omega.log
omega_data.json
test_omega_data.json
*.data.json

# ------------------------------------------------------------------
# NuGet
# ------------------------------------------------------------------
packages/
*.nupkg

# ------------------------------------------------------------------
# Python
# ------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
*.egg
.venv/
venv/
env/

# ------------------------------------------------------------------
# Node (if UI added later)
# ------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------------------------------------------------
# Docker
# ------------------------------------------------------------------
.docker/
docker-compose.override.yml

# ------------------------------------------------------------------
# Testing Artifacts
# ------------------------------------------------------------------
coverage/
*.coverage
*.trx
TestResults/

# ------------------------------------------------------------------
# Temp & Cache
# ------------------------------------------------------------------
*.tmp
*.temp
.cache/
